ROBIN_HOST=127.0.0.1
ROBIN_PORT=3939
ROBIN_PANEL_TOKEN=store-in-keychain-not-here
ROBIN_MODE=simulator
ROBIN_OPENAI_MODEL=gpt-5.6
ROBIN_REALTIME_MODEL=gpt-realtime-2.1
ROBIN_HELPER_SOCKET=/tmp/robin-helper.sock
ROBIN_TRACE_DIR=./traces
ROBIN_ALLOWED_APPS=us.zoom.xos,com.apple.Safari,com.apple.TextEdit,com.microsoft.VSCode
ROBIN_WORKSPACE_DISPLAY=1
ROBIN_AUDIO_INPUT=Robin Speaker
ROBIN_AUDIO_OUTPUT=Robin Microphone
